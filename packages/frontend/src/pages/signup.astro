---
import AuthLayout from '@/layouts/AuthLayout.astro'
import { pressClasses, focusRingClasses } from '@/lib/interaction-classes'

const error = Astro.url.searchParams.get('error')
---

<AuthLayout title="Registrieren">
  <div class="min-h-screen flex items-center justify-center bg-base-100 p-4">
    <div class="card w-full max-w-md bg-base-200 shadow-xl">
      <div class="card-body">
        <h1 class="card-title text-2xl font-bold text-center justify-center mb-6">
          Registrieren
        </h1>

        {error && (
          <div class="alert alert-error mb-4">
            <span>{decodeURIComponent(error)}</span>
          </div>
        )}

        <form method="POST" action="/api/auth/signup" class="space-y-4" data-loading-submit>
          <fieldset>
            <label class="label" for="email">E-Mail</label>
            <input
              type="email"
              id="email"
              name="email"
              data-testid="signup-email"
              placeholder="name@example.com"
              class:list={['input w-full', focusRingClasses]}
              required
              autocomplete="email"
            />
          </fieldset>

          <fieldset>
            <label class="label" for="password">Passwort</label>
            <input
              type="password"
              id="password"
              name="password"
              data-testid="signup-password"
              placeholder="********"
              class:list={['input w-full', focusRingClasses]}
              required
              minlength="8"
              autocomplete="new-password"
            />
          </fieldset>

          <fieldset>
            <label class="label" for="passwordConfirm">Passwort bestätigen</label>
            <input
              type="password"
              id="passwordConfirm"
              name="passwordConfirm"
              data-testid="signup-password-confirm"
              placeholder="********"
              class:list={['input w-full', focusRingClasses]}
              required
              minlength="8"
              autocomplete="new-password"
            />
          </fieldset>

          <div class="mt-6">
            <button type="submit" data-testid="signup-submit" class:list={['btn btn-primary w-full', pressClasses, focusRingClasses]}>
              Registrieren
            </button>
          </div>
        </form>

        <div class="divider">oder</div>

        <p class="text-center">
          Bereits registriert? <a href="/login" class:list={['link link-primary', focusRingClasses]}>Anmelden</a>
        </p>
      </div>
    </div>
  </div>
</AuthLayout>
